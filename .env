# ================================
# CONFIGURACIÓN DE BASE DE DATOS
# ================================
# Aquí puedes elegir qué base de datos usar en tu bot.
# SOLO debes dejar activa UNA opción (DB_DRIVER) y comentar las demás.

# Por defecto: LowDB
DB_DRIVER=lowdb
LOWDB_PATH=./database.json

# SQLite
# DB_DRIVER=sqlite
SQLITE_PATH=./database.sqlite

# PostgreSQL 
# DB_DRIVER=postgres
POSTGRES_URL=postgresql://usuario:contraseña@host:puerto/database

# MariaDB / MySQL
# DB_DRIVER=mariadb
MYSQL_URL=mysql://usuario:contraseña@host:puerto/database

# MongoDB
# DB_DRIVER=mongodb
MONGO_URL=mongodb://127.0.0.1:27017/database

# NOTA:
# - Solo una opción debe estar activa en DB_DRIVER
# - Asegúrate de configurar correctamente la URL según tu servidor
# - Si no sabes cuál usar, deja "lowdb"
